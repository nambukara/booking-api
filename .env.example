# API Configuration
PORT=3000

# Database Configuration (PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Use 'localhost' when running the API locally, or 'db' when running within docker-compose
DATABASE_URL="postgresql://postgres:mysecretpassword@localhost:5432/booking_platform?schema=public"

# Authentication
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES=1d
